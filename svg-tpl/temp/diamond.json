{
	"name": "diamond",
	"label": "Diamond",
	"view": {

        "scale_1": {
			"type": "range",
			"default": 0.25,
			"min": 0.01,
			"max": 0.5,
			"step": 0.01,
			"label": "Scale"
		},


		"dx": {
			"type": "range",
			"default": 20,
			"min": 8,
			"max": 255,
			"step": 0.5,
			"label": "DX"
		},
		"halfx": {
			"type": "jsf",
			"calc": "return Math.floor( data.dx.value / 2 );"
		},
		"dy": {
			"type": "range",
			"default": 20,
			"min": 8,
			"max": 255,
			"step": 0.5,
			"label": "DY"
		},
		"halfy": {
			"type": "jsf",
			"calc": "return Math.floor( data.dy.value / 2 );"
		},
		"stroke_width": {
			"type": "range",
			"default": 2,
			"min": 0.5,
			"max": 40,
			"step": 0.5,
			"label": "Stroke Width"
		},
		"colorpanel": {
			"type": "colorpanel",
			"label": "Colors",
			"default": {
				"background": { "label": "Background", "default": "#ff0000" },
				"color_1": { "label": "Color 1", "default": "#00ff00" }
			}
		},

		"color_1": {
			"type": "jsf",
			"calc": "return ( data.colorpanel.value.color_1.value );"
		},
		"bg_fill": {
			"type": "jsf",
			"calc": "return ( data.colorpanel.value.background.value );"
		}
	},
	"presets" : [
		{
			"label" : "Cardinal",
			"view" : {
				"scale_1": 0.1 ,
				"dx" : 60,
				"dy" : 100,
				"colorpanel": {
					"background": "#450874",
					"color_1": "#ece49f"
				}
			}
		},
		{
			"label" : "Leaves",
			"view" : {
				"scale_1": 0.04 ,
				"dx" : 150,
				"dy" : 250,
				"colorpanel": {
					"background": "#FBFAF3",
					"color_1": "#19AF53"
				}
			}
		}

	],
	"template": "file"
}
